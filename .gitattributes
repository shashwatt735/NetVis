# Normalize all text files to LF in the repo
* text=auto eol=lf

# Source files — explicit LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf

# Markup / styles
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf

# Data / config
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.env   text eol=lf
*.xml   text eol=lf

# Docs
*.md    text eol=lf
*.txt   text eol=lf
*.svg   text eol=lf

# Shell scripts (break on CRLF)
*.sh    text eol=lf
*.bash  text eol=lf

# Lock files
package-lock.json  text eol=lf
yarn.lock          text eol=lf
pnpm-lock.yaml     text eol=lf

# Binary — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.mp4   binary
*.mp3   binary
*.zip   binary
*.node  binary
