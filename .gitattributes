# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Explicitly LF for source files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.mjs   text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.icns  binary
*.node  binary
